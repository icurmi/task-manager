  render();window.scrollTo(0,0);
}
function setTaskView(m){
  taskViewMode=m;
  document.getElementById('vt-list').classList.toggle('active',m==='list');
  document.getElementById('vt-kanban').classList.toggle('active',m==='kanban');
  render();
}
function setFilter(type,val){if(type==='status')filterStatus=val;else filterPrio=val;render();}
function toggleTask(id){const t=data.tasks.find(x=>x.id===id);if(t){t.status=t.status==='done'?'todo':'done';scheduleSave();render();}}
function deleteTask(id){if(!confirm('Delete this task?'))return;data.tasks=data.tasks.filter(x=>x.id!==id);scheduleSave();render();}
function deleteTaskFromModal(){if(!confirm('Delete this task?'))return;data.tasks=data.tasks.filter(x=>x.id!==editTaskId);closeTaskModal();scheduleSave();render();}
function deleteProjFromModal(){
  if(!confirm('Delete this project? Tasks will remain but lose their project link.'))return;
  data.tasks.forEach(t=>{if(t.projId===editProjId)t.projId=null;});
  data.projects=data.projects.filter(x=>x.id!==editProjId);
  closeProjModal();scheduleSave();showView('projects');
}
function deleteAreaFromModal(){
  const cnt=data.tasks.filter(t=>t.areaId===editAreaId).length+data.projects.filter(p=>p.areaId===editAreaId).length;
  if(!confirm(`Delete this area? ${cnt} linked item(s) will remain.`))return;
  data.areas=data.areas.filter(x=>x.id!==editAreaId);
  closeAreaModal();scheduleSave();showView('home');
}

