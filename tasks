  lbl.textContent=msg;
}

/* ── SUPABASE LOAD ── */
async function loadFromSupabase(){
  syncStatus('loading','Connecting...');
  try{
    const res=await fetch(`${SB_URL}/rest/v1/tm_data?id=eq.singleton&select=payload`,{headers:SB_HEADERS});
    if(!res.ok)throw new Error('fetch failed');
    const rows=await res.json();
    if(rows.length&&rows[0].payload&&rows[0].payload.areas&&rows[0].payload.areas.length){
      data=rows[0].payload;
      syncStatus('ok','Synced');
    }else{
      data=defaultData();
      await pushToSupabase();
    }
  }catch(e){
    syncStatus('err','Offline — using local');
    loadLocal();
  }
  render();
}

/* ── SUPABASE SAVE ── */
async function pushToSupabase(){
  syncStatus('saving','Saving...');
  saveLocal();
  try{
    const res=await fetch(`${SB_URL}/rest/v1/tm_data?id=eq.singleton`,{
      method:'PATCH',headers:{...SB_HEADERS,'Prefer':'return=minimal'},
      body:JSON.stringify({payload:data,updated_at:new Date().toISOString()})
    });
    if(!res.ok)throw new Error('save failed');
    syncStatus('ok','Saved');
  }catch(e){syncStatus('err','Save failed — stored locally');}
}

function scheduleSave(){
  clearTimeout(saveTimer);
  saveTimer=setTimeout(()=>pushToSupabase(),800);
