  const asel=document.getElementById('tm-area');
  asel.innerHTML=data.areas.map(a=>`<option value="${a.id}">${esc(a.name)}</option>`).join('');
  const psel=document.getElementById('tm-project');
  psel.innerHTML='<option value="">— no project —</option>'+data.projects.map(p=>`<option value="${p.id}">${esc(p.name)}</option>`).join('');
  document.getElementById('tm-delete').style.display=id!==null?'block':'none';
  if(id!==null){
    const t=data.tasks.find(x=>x.id===id);
    document.getElementById('tm-name').value=t.name;
    document.getElementById('tm-notes').value=t.notes||'';
    asel.value=t.areaId;
    document.getElementById('tm-prio').value=t.prio;
    document.getElementById('tm-status').value=t.status;
    document.getElementById('tm-due').value=t.due||'';
    psel.value=t.projId||'';
    document.getElementById('taskModalTitle').textContent='Edit task';
  }else{
    document.getElementById('tm-name').value='';
    document.getElementById('tm-notes').value='';
    asel.value=curArea||(data.areas[0]?.id||'');
    document.getElementById('tm-prio').value='medium';
    document.getElementById('tm-status').value=prefillStatus||'todo';
    document.getElementById('tm-due').value='';
    psel.value=curProj||'';
    document.getElementById('taskModalTitle').textContent='New task';
  }
  prefillStatus=null;
  document.getElementById('taskModalBg').classList.add('open');
  setTimeout(()=>document.getElementById('tm-name').focus(),50);
}
function closeTaskModal(){document.getElementById('taskModalBg').classList.remove('open');}
function saveTask(){
  const name=document.getElementById('tm-name').value.trim();
  if(!name){document.getElementById('tm-name').focus();return;}
  const proj=document.getElementById('tm-project').value;
  const d={name,notes:document.getElementById('tm-notes').value,areaId:parseInt(document.getElementById('tm-area').value),
    prio:document.getElementById('tm-prio').value,status:document.getElementById('tm-status').value,
    due:document.getElementById('tm-due').value,projId:proj?parseInt(proj):null};
  if(editTaskId!==null)Object.assign(data.tasks.find(x=>x.id===editTaskId),d);
  else data.tasks.unshift({id:data.nextTaskId++,...d});
  closeTaskModal();scheduleSave();render();
}

function openProjModal(id){
  editProjId=id;
  const asel=document.getElementById('pm-area');
  asel.innerHTML=data.areas.map(a=>`<option value="${a.id}">${esc(a.name)}</option>`).join('');
  document.getElementById('pm-delete').style.display=id!==null?'block':'none';
  if(id!==null){
    const p=data.projects.find(x=>x.id===id);
    document.getElementById('pm-name').value=p.name;
    document.getElementById('pm-desc').value=p.desc||'';
    asel.value=p.areaId;
    document.getElementById('pm-status').value=p.status;
    document.getElementById('pm-start').value=p.start||'';
    document.getElementById('pm-due').value=p.due||'';
    document.getElementById('projModalTitle').textContent='Edit project';
  }else{
    document.getElementById('pm-name').value='';
    document.getElementById('pm-desc').value='';
    asel.value=curArea||(data.areas[0]?.id||'');
    document.getElementById('pm-status').value='active';
    document.getElementById('pm-start').value='';
    document.getElementById('pm-due').value='';
    document.getElementById('projModalTitle').textContent='New project';
  }
  document.getElementById('projModalBg').classList.add('open');
  setTimeout(()=>document.getElementById('pm-name').focus(),50);
}
function closeProjModal(){document.getElementById('projModalBg').classList.remove('open');}
function saveProject(){
  const name=document.getElementById('pm-name').value.trim();
  if(!name){document.getElementById('pm-name').focus();return;}
  const d={name,desc:document.getElementById('pm-desc').value,areaId:parseInt(document.getElementById('pm-area').value),
    status:document.getElementById('pm-status').value,start:document.getElementById('pm-start').value,due:document.getElementById('pm-due').value};
  if(editProjId!==null)Object.assign(data.projects.find(x=>x.id===editProjId),d);
  else data.projects.push({id:data.nextProjId++,...d});
  closeProjModal();scheduleSave();render();
}

function buildColourPicker(){
  document.getElementById('colour-opts').innerHTML=COLOURS.map(c=>`
    <div class="colour-opt${selColour===c.key?' selected':''}" style="background:${c.hex}" onclick="pickColour('${c.key}')" title="${c.key}" role="radio" aria-checked="${selColour===c.key}" aria-label="${c.key}"></div>`).join('');
}
function pickColour(key){selColour=key;buildColourPicker();}
function openAreaModal(id){
  editAreaId=id;
  document.getElementById('am-delete').style.display=id!==null?'block':'none';
  if(id!==null){
    const a=data.areas.find(x=>x.id===id);
    document.getElementById('am-name').value=a.name;
    selColour=a.colour||'purple';
    document.getElementById('areaModalTitle').textContent='Edit area';
  }else{
    document.getElementById('am-name').value='';
    selColour='purple';
    document.getElementById('areaModalTitle').textContent='New area';
  }
  buildColourPicker();
  document.getElementById('areaModalBg').classList.add('open');
  setTimeout(()=>document.getElementById('am-name').focus(),50);
}
function closeAreaModal(){document.getElementById('areaModalBg').classList.remove('open');}
function saveArea(){
  const name=document.getElementById('am-name').value.trim();
  if(!name){document.getElementById('am-name').focus();return;}
  if(editAreaId!==null)Object.assign(data.areas.find(x=>x.id===editAreaId),{name,colour:selColour});
  else data.areas.push({id:data.nextAreaId++,name,colour:selColour});
  closeAreaModal();scheduleSave();render();
}

['taskModalBg','projModalBg','areaModalBg'].forEach(id=>{
  document.getElementById(id).addEventListener('click',e=>{if(e.target===document.getElementById(id)){closeTaskModal();closeProjModal();closeAreaModal();}});
});
document.addEventListener('keydown',e=>{if(e.key==='Escape'){closeTaskModal();closeProjModal();closeAreaModal();}});

loadFromSupabase();
</script>
</body>
</html>
