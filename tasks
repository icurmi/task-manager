<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Personal | Task Manager</title>
<meta name="description" content="Personal task and project manager — organised by area, project, and priority."/>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%237F77DD'/><rect x='7' y='9' width='11' height='3' rx='1.5' fill='white'/><rect x='7' y='14.5' width='14' height='3' rx='1.5' fill='white'/><rect x='7' y='20' width='8' height='3' rx='1.5' fill='white'/><circle cx='24' cy='21.5' r='5' fill='%23EF9F27'/><path d='M21.5 21.5 L23.2 23.2 L26.5 19.8' stroke='white' stroke-width='1.6' stroke-linecap='round' stroke-linejoin='round' fill='none'/></svg>"/>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&display=swap" rel="stylesheet"/>
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css"/>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#F9F9F8;--surface:#FFFFFF;--surface2:#F1F1EF;
  --border:rgba(0,0,0,0.08);--border2:rgba(0,0,0,0.13);
  --text:#1A1A1A;--text2:#6B6B6B;--text3:#A8A8A3;
  --sidebar-w:224px;--radius:8px;--radius-sm:5px;
  --high-bg:#FCEBEB;--high-tx:#791F1F;
  --med-bg:#FFF8E6;--med-tx:#7A4F00;
  --low-bg:#EAF3DE;--low-tx:#27500A;
  --done-bg:#F1F1EF;--done-tx:#6B6B6B;
  --inprog-bg:#EEF2FF;--inprog-tx:#3730A3;
  --todo-bg:#F9F9F8;--todo-tx:#374151;
}
@media(prefers-color-scheme:dark){:root{
  --bg:#111110;--surface:#1C1C1A;--surface2:#252523;
  --border:rgba(255,255,255,0.07);--border2:rgba(255,255,255,0.13);
  --text:#F0EFEA;--text2:#9A9990;--text3:#5C5B56;
  --high-bg:#501313;--high-tx:#F7C1C1;
  --med-bg:#412402;--med-tx:#FAC775;
  --low-bg:#173404;--low-tx:#C0DD97;
  --done-bg:#252523;--done-tx:#9A9990;
  --inprog-bg:#1E1B4B;--inprog-tx:#A5B4FC;
  --todo-bg:#1C1C1A;--todo-tx:#D1D5DB;
}}
.ac-purple{--ac:#7F77DD;--ac-bg:#EEEDFE;--ac-tx:#3C3489;}
.ac-blue{--ac:#378ADD;--ac-bg:#E6F1FB;--ac-tx:#0C447C;}
.ac-teal{--ac:#1D9E75;--ac-bg:#E1F5EE;--ac-tx:#085041;}
.ac-amber{--ac:#EF9F27;--ac-bg:#FAEEDA;--ac-tx:#633806;}
.ac-coral{--ac:#D85A30;--ac-bg:#FAECE7;--ac-tx:#4A1B0C;}
.ac-pink{--ac:#D4537E;--ac-bg:#FBEAF0;--ac-tx:#4B1528;}
.ac-green{--ac:#639922;--ac-bg:#EAF3DE;--ac-tx:#27500A;}
.ac-red{--ac:#E24B4A;--ac-bg:#FCEBEB;--ac-tx:#501313;}
@media(prefers-color-scheme:dark){
.ac-purple{--ac-bg:#26215C;--ac-tx:#CECBF6;}
.ac-blue{--ac-bg:#042C53;--ac-tx:#B5D4F4;}
.ac-teal{--ac-bg:#04342C;--ac-tx:#9FE1CB;}
.ac-amber{--ac-bg:#412402;--ac-tx:#FAC775;}
.ac-coral{--ac-bg:#4A1B0C;--ac-tx:#F0997B;}
.ac-pink{--ac-bg:#4B1528;--ac-tx:#ED93B1;}
.ac-green{--ac-bg:#173404;--ac-tx:#C0DD97;}
.ac-red{--ac-bg:#501313;--ac-tx:#F7C1C1;}
}
body{font-family:'Inter',system-ui,sans-serif;background:var(--bg);color:var(--text);font-size:14px;line-height:1.5;min-height:100vh;display:flex;}
.sidebar{width:var(--sidebar-w);flex-shrink:0;background:var(--surface);border-right:0.5px solid var(--border2);display:flex;flex-direction:column;position:fixed;top:0;bottom:0;left:0;overflow-y:auto;}
.sb-logo{padding:16px 14px 12px;font-size:14px;font-weight:600;letter-spacing:-0.2px;display:flex;align-items:center;gap:8px;border-bottom:0.5px solid var(--border);}
.sb-logo i{font-size:18px;color:var(--text2);}
.sync-dot{width:7px;height:7px;border-radius:50%;margin-left:auto;flex-shrink:0;}
.sync-dot.ok{background:#1D9E75;}.sync-dot.saving{background:#EF9F27;}.sync-dot.err{background:#E24B4A;}.sync-dot.loading{background:var(--text3);}
.sb-section{padding:10px 14px 4px;font-size:10px;font-weight:600;letter-spacing:0.08em;text-transform:uppercase;color:var(--text3);display:flex;align-items:center;justify-content:space-between;}
.sb-section button{background:none;border:none;cursor:pointer;color:var(--text3);font-size:15px;display:flex;padding:0;line-height:1;}
.sb-section button:hover{color:var(--text2);}
.sb-item{display:flex;align-items:center;gap:8px;padding:6px 10px;margin:1px 6px;border-radius:var(--radius-sm);cursor:pointer;font-size:13px;color:var(--text2);border:none;background:none;width:calc(100% - 12px);text-align:left;font-family:inherit;}
.sb-item:hover,.sb-item.active{background:var(--surface2);color:var(--text);}
.sb-item i{font-size:15px;flex-shrink:0;}
.sb-count{margin-left:auto;font-size:11px;background:var(--surface2);padding:1px 7px;border-radius:999px;color:var(--text3);flex-shrink:0;}
.sb-item.active .sb-count{background:var(--border2);}
.sb-dot{width:8px;height:8px;border-radius:50%;flex-shrink:0;}
.sb-divider{height:0.5px;background:var(--border);margin:6px 10px;}
.sb-ghost{margin:4px 6px;border:0.5px dashed var(--border2);border-radius:var(--radius-sm);padding:6px 10px;font-size:12px;color:var(--text3);cursor:pointer;text-align:center;background:none;font-family:inherit;width:calc(100% - 12px);display:flex;align-items:center;justify-content:center;gap:5px;}
.sb-ghost:hover{border-color:var(--text3);color:var(--text2);}
.main{margin-left:var(--sidebar-w);flex:1;display:flex;flex-direction:column;min-height:100vh;}
.topbar{padding:0 24px;height:50px;display:flex;align-items:center;gap:10px;border-bottom:0.5px solid var(--border);background:var(--surface);position:sticky;top:0;z-index:50;}
.topbar h1{font-size:15px;font-weight:600;flex:1;}
.topbar-actions{display:flex;gap:6px;align-items:center;}
.view-toggle{display:flex;gap:2px;background:var(--surface2);border-radius:var(--radius-sm);padding:2px;}
.view-btn{background:none;border:none;padding:5px 9px;border-radius:4px;cursor:pointer;font-size:14px;color:var(--text3);}
.view-btn.active,.view-btn:hover{background:var(--surface);color:var(--text);}
.btn-sm{font-size:12px;padding:5px 12px;border-radius:var(--radius-sm);cursor:pointer;font-family:inherit;font-weight:500;display:flex;align-items:center;gap:5px;border:0.5px solid var(--border2);background:var(--surface);color:var(--text2);white-space:nowrap;}
.btn-sm:hover{color:var(--text);}
.btn-primary{background:var(--text);color:var(--bg);border-color:transparent;}
.btn-primary:hover{opacity:0.85;}
.content{padding:24px 28px;flex:1;}
.stat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:10px;margin-bottom:20px;}
.stat-card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius);padding:12px 14px;}
.stat-n{font-size:24px;font-weight:600;letter-spacing:-0.5px;}
.stat-l{font-size:11px;color:var(--text2);margin-top:2px;}
.area-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(160px,1fr));gap:10px;margin-bottom:24px;}
.area-card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius);padding:14px 16px;cursor:pointer;transition:border-color 0.12s;position:relative;}
.area-card:hover{border-color:var(--border2);}
.area-card-dot{width:10px;height:10px;border-radius:50%;margin-bottom:10px;}
.area-card-name{font-size:13px;font-weight:500;margin-bottom:3px;}
.area-card-sub{font-size:11px;color:var(--text3);}
.area-card-edit{position:absolute;top:8px;right:8px;opacity:0;}
.area-card:hover .area-card-edit{opacity:1;}
.section-head{font-size:12px;font-weight:600;color:var(--text2);margin-bottom:10px;display:flex;align-items:center;justify-content:space-between;}
.proj-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:10px;margin-bottom:24px;}
.proj-card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius);padding:14px 16px;cursor:pointer;transition:border-color 0.12s;}
.proj-card:hover{border-color:var(--border2);}
.proj-card-header{display:flex;align-items:center;gap:8px;margin-bottom:8px;}
.proj-card-name{font-size:13px;font-weight:500;flex:1;}
.proj-progress{height:3px;background:var(--surface2);border-radius:99px;margin-bottom:8px;overflow:hidden;}
.proj-progress-fill{height:100%;border-radius:99px;}
.proj-meta{display:flex;gap:6px;align-items:center;flex-wrap:wrap;}
.task-table{width:100%;border-collapse:collapse;}
.task-table th{font-size:10px;font-weight:600;color:var(--text3);text-align:left;padding:6px 10px;border-bottom:0.5px solid var(--border2);text-transform:uppercase;letter-spacing:0.05em;}
.task-row{border-bottom:0.5px solid var(--border);}
.task-row:hover{background:var(--surface2);}
.task-row.done-row td{opacity:0.42;}
.task-row.done-row .task-name{text-decoration:line-through;}
.task-row td{padding:8px 10px;vertical-align:middle;}
.check{width:16px;height:16px;border-radius:50%;border:1.5px solid var(--border2);cursor:pointer;display:flex;align-items:center;justify-content:center;flex-shrink:0;}
.check:hover{border-color:var(--text3);}
.check.on{background:var(--text);border-color:var(--text);}
.check.on::after{content:'';width:5px;height:5px;border-radius:50%;background:var(--bg);display:block;}
.task-name{font-size:13px;cursor:pointer;}
.task-name:hover{text-decoration:underline;}
.task-name-wrap{display:flex;align-items:center;gap:7px;}
.notes-dot{width:5px;height:5px;border-radius:50%;background:var(--text3);flex-shrink:0;}
.row-actions{display:flex;gap:2px;opacity:0;}
.task-row:hover .row-actions{opacity:1;}
.kanban{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;}
.k-col{background:var(--surface2);border-radius:var(--radius);padding:10px;}
.k-col-head{font-size:10px;font-weight:600;letter-spacing:0.06em;text-transform:uppercase;color:var(--text2);padding:4px 4px 10px;display:flex;align-items:center;gap:6px;}
.k-count{font-size:11px;background:var(--border2);padding:1px 7px;border-radius:999px;color:var(--text3);}
.k-card{background:var(--surface);border:0.5px solid var(--border);border-radius:var(--radius-sm);padding:10px 12px;margin-bottom:6px;cursor:pointer;}
.k-card:hover{border-color:var(--border2);}
.k-card-name{font-size:13px;margin-bottom:6px;}
.k-card-meta{display:flex;gap:5px;flex-wrap:wrap;}
.badge{font-size:11px;font-weight:500;padding:2px 8px;border-radius:999px;white-space:nowrap;}
.b-area{background:var(--ac-bg);color:var(--ac-tx);}
.b-high{background:var(--high-bg);color:var(--high-tx);}
.b-medium{background:var(--med-bg);color:var(--med-tx);}
.b-low{background:var(--low-bg);color:var(--low-tx);}
.b-todo{background:var(--todo-bg);color:var(--todo-tx);border:0.5px solid var(--border2);}
.b-inprogress{background:var(--inprog-bg);color:var(--inprog-tx);}
.b-done{background:var(--done-bg);color:var(--done-tx);}
.due-pill{font-size:11px;color:var(--text3);display:flex;align-items:center;gap:3px;}
.due-pill.overdue{color:#E24B4A;}
.icon-btn{background:none;border:none;cursor:pointer;color:var(--text3);padding:4px;border-radius:4px;font-size:15px;display:inline-flex;align-items:center;line-height:1;}
.icon-btn:hover{background:var(--surface2);color:var(--text);}
.empty-state{text-align:center;padding:40px 24px;color:var(--text3);}
.empty-state i{font-size:28px;display:block;margin-bottom:8px;}
.breadcrumb{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--text3);margin-bottom:18px;}
.breadcrumb span{cursor:pointer;}
.breadcrumb span:hover{color:var(--text);}
.filter-bar{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:14px;}
.pill{font-size:12px;padding:4px 11px;border-radius:999px;border:0.5px solid var(--border2);background:transparent;color:var(--text2);cursor:pointer;font-family:inherit;}
.pill:hover{color:var(--text);border-color:var(--text3);}
.pill.active{background:var(--text);color:var(--bg);border-color:transparent;}
.modal-bg{display:none;position:fixed;inset:0;background:rgba(0,0,0,0.38);z-index:200;align-items:center;justify-content:center;padding:1rem;}
.modal-bg.open{display:flex;}
.modal{background:var(--surface);border:0.5px solid var(--border2);border-radius:12px;padding:1.4rem;width:100%;max-width:460px;display:flex;flex-direction:column;gap:13px;}
.modal-head{display:flex;align-items:center;justify-content:space-between;}
.modal-head h2{font-size:15px;font-weight:600;}
.field label{font-size:10px;font-weight:600;color:var(--text2);display:block;margin-bottom:5px;text-transform:uppercase;letter-spacing:0.05em;}
.field input,.field select,.field textarea{width:100%;background:var(--bg);border:0.5px solid var(--border2);border-radius:var(--radius-sm);padding:8px 10px;font-size:13px;color:var(--text);font-family:inherit;outline:none;}
.field input:focus,.field select:focus,.field textarea:focus{border-color:var(--text3);}
.field textarea{height:68px;resize:vertical;}
.field-row{display:grid;grid-template-columns:1fr 1fr;gap:10px;}
.field-row3{display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;}
.modal-btns{display:flex;justify-content:space-between;align-items:center;padding-top:2px;}
.modal-btns-right{display:flex;gap:8px;}
.modal-btns button{padding:7px 16px;border-radius:var(--radius-sm);font-size:13px;font-weight:500;cursor:pointer;font-family:inherit;}
.btn-cancel{background:none;border:0.5px solid var(--border2);color:var(--text2);}
.btn-save{background:var(--text);color:var(--bg);border:none;}
.btn-cancel:hover{color:var(--text);}
.btn-save:hover{opacity:0.85;}
.btn-danger{background:none;border:none;color:#E24B4A;font-size:13px;cursor:pointer;font-family:inherit;padding:7px 0;}
.btn-danger:hover{text-decoration:underline;}
.colour-opts{display:flex;gap:8px;flex-wrap:wrap;}
.colour-opt{width:24px;height:24px;border-radius:50%;cursor:pointer;border:2px solid transparent;transition:transform 0.1s;}
.colour-opt:hover{transform:scale(1.15);}
.colour-opt.selected{border-color:var(--text);}
.sync-bar{font-size:11px;color:var(--text3);padding:6px 14px;display:flex;align-items:center;gap:6px;border-top:0.5px solid var(--border);margin-top:auto;}
.sync-bar i{font-size:13px;}
@media(max-width:680px){
  .sidebar{display:none;}.main{margin-left:0;}
  .stat-grid{grid-template-columns:1fr 1fr;}
  .kanban{grid-template-columns:1fr;}
  .proj-grid,.area-grid{grid-template-columns:1fr;}
}
</style>
</head>
<body>

<nav class="sidebar" id="sidebar">
  <div class="sb-logo">
    <i class="ti ti-layout-kanban"></i> My Workspace
    <span class="sync-dot loading" id="syncDot" title="Sync status"></span>
  </div>
  <div class="sb-section" style="padding-bottom:6px">Views</div>
  <button class="sb-item" id="nav-home" onclick="showView('home')"><i class="ti ti-home"></i> Home</button>
  <button class="sb-item" id="nav-tasks" onclick="showView('tasks')"><i class="ti ti-checkbox"></i> All Tasks <span class="sb-count" id="sc-tasks">0</span></button>
  <button class="sb-item" id="nav-projects" onclick="showView('projects')"><i class="ti ti-folders"></i> Projects <span class="sb-count" id="sc-projects">0</span></button>
  <div class="sb-divider"></div>
  <div class="sb-section">Areas <button onclick="openAreaModal(null)" title="Add area"><i class="ti ti-plus"></i></button></div>
  <div id="sb-areas"></div>
  <button class="sb-ghost" onclick="openAreaModal(null)"><i class="ti ti-plus"></i> New area</button>
  <div class="sb-divider"></div>
  <div class="sb-section">Projects <button onclick="openProjModal(null)" title="Add project"><i class="ti ti-plus"></i></button></div>
  <div id="sb-projects"></div>
  <button class="sb-ghost" onclick="openProjModal(null)"><i class="ti ti-plus"></i> New project</button>
  <div class="sync-bar" id="syncBar"><i class="ti ti-cloud"></i> <span id="syncLabel">Connecting...</span></div>
</nav>

<div class="main">
  <div class="topbar">
    <h1 id="topbar-title">Home</h1>
    <div class="topbar-actions">
      <div class="view-toggle" id="viewToggle" style="display:none">
        <button class="view-btn active" id="vt-list" onclick="setTaskView('list')" title="List"><i class="ti ti-list"></i></button>
        <button class="view-btn" id="vt-kanban" onclick="setTaskView('kanban')" title="Kanban"><i class="ti ti-layout-columns"></i></button>
      </div>
      <button class="btn-sm btn-primary" id="btn-add-task" onclick="openTaskModal(null)" style="display:none"><i class="ti ti-plus"></i> Task</button>
      <button class="btn-sm btn-primary" id="btn-add-proj" onclick="openProjModal(null)" style="display:none"><i class="ti ti-plus"></i> Project</button>
      <button class="btn-sm btn-primary" id="btn-add-area" onclick="openAreaModal(null)" style="display:none"><i class="ti ti-plus"></i> Area</button>
      <button class="btn-sm btn-primary" id="btn-add-home" onclick="openTaskModal(null)"><i class="ti ti-plus"></i> Add task</button>
    </div>
  </div>
  <div class="content" id="content"></div>
</div>

<!-- TASK MODAL -->
<div class="modal-bg" id="taskModalBg">
  <div class="modal">
    <div class="modal-head"><h2 id="taskModalTitle">New task</h2><button class="icon-btn" onclick="closeTaskModal()"><i class="ti ti-x"></i></button></div>
    <div class="field"><label>Task name</label><input type="text" id="tm-name" placeholder="What needs doing?"/></div>
    <div class="field"><label>Notes</label><textarea id="tm-notes" placeholder="Context, links, details..."></textarea></div>
    <div class="field-row3">
      <div class="field"><label>Area</label><select id="tm-area"></select></div>
      <div class="field"><label>Priority</label>
        <select id="tm-prio"><option value="high">High</option><option value="medium" selected>Medium</option><option value="low">Low</option></select>
      </div>
      <div class="field"><label>Status</label>
        <select id="tm-status"><option value="todo">To do</option><option value="inprogress">In progress</option><option value="done">Done</option></select>
      </div>
    </div>
    <div class="field-row">
      <div class="field"><label>Project</label><select id="tm-project"><option value="">— no project —</option></select></div>
      <div class="field"><label>Due date</label><input type="date" id="tm-due"/></div>
    </div>
    <div class="modal-btns">
      <button class="btn-danger" id="tm-delete" onclick="deleteTaskFromModal()" style="display:none">Delete task</button>
      <div class="modal-btns-right">
        <button class="btn-cancel" onclick="closeTaskModal()">Cancel</button>
        <button class="btn-save" onclick="saveTask()">Save task</button>
      </div>
    </div>
  </div>
</div>

<!-- PROJECT MODAL -->
<div class="modal-bg" id="projModalBg">
  <div class="modal">
    <div class="modal-head"><h2 id="projModalTitle">New project</h2><button class="icon-btn" onclick="closeProjModal()"><i class="ti ti-x"></i></button></div>
    <div class="field"><label>Project name</label><input type="text" id="pm-name" placeholder="Project name"/></div>
    <div class="field"><label>Description</label><textarea id="pm-desc" placeholder="What is this project about?"></textarea></div>
    <div class="field-row">
      <div class="field"><label>Area</label><select id="pm-area"></select></div>
      <div class="field"><label>Status</label>
        <select id="pm-status"><option value="active">Active</option><option value="onhold">On hold</option><option value="done">Done</option></select>
      </div>
    </div>
    <div class="field-row">
      <div class="field"><label>Start date</label><input type="date" id="pm-start"/></div>
      <div class="field"><label>Due date</label><input type="date" id="pm-due"/></div>
    </div>
    <div class="modal-btns">
      <button class="btn-danger" id="pm-delete" onclick="deleteProjFromModal()" style="display:none">Delete project</button>
      <div class="modal-btns-right">
        <button class="btn-cancel" onclick="closeProjModal()">Cancel</button>
        <button class="btn-save" onclick="saveProject()">Save project</button>
      </div>
    </div>
  </div>
</div>

<!-- AREA MODAL -->
<div class="modal-bg" id="areaModalBg">
  <div class="modal" style="max-width:380px">
    <div class="modal-head"><h2 id="areaModalTitle">New area</h2><button class="icon-btn" onclick="closeAreaModal()"><i class="ti ti-x"></i></button></div>
    <div class="field"><label>Area name</label><input type="text" id="am-name" placeholder="e.g. BRND WGN, Freelance..."/></div>
    <div class="field"><label>Colour</label><div class="colour-opts" id="colour-opts"></div></div>
    <div class="modal-btns">
      <button class="btn-danger" id="am-delete" onclick="deleteAreaFromModal()" style="display:none">Delete area</button>
      <div class="modal-btns-right">
        <button class="btn-cancel" onclick="closeAreaModal()">Cancel</button>
        <button class="btn-save" onclick="saveArea()">Save area</button>
      </div>
    </div>
  </div>
</div>

<script>
